<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:context=".MonitorActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/monitor_usage_title"
            app:titleCentered="true" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/monitor_best_effort_notice"
                android:textSize="12sp"
                android:alpha="0.6"
                android:layout_marginBottom="12dp" />

            <!-- Memory -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.HostAI.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monitor_memory_title"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/ramText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— MB / — MB"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace" />
                    <ProgressBar
                        android:id="@+id/ramProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Power -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.HostAI.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monitor_power_title"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/powerCurrentText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current: — mA"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:id="@+id/powerVoltageText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voltage: — V"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:id="@+id/powerWattsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Power: — W"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Thermals -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.HostAI.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monitor_thermal_title"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/batteryTempText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Battery: — °C"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:id="@+id/thermalStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: —"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Network -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.HostAI.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monitor_network_title"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/netDownText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Down: — KB/s"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:id="@+id/netUpText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Up: — KB/s"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Processor -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.HostAI.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monitor_cpu_title"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/cpuAppText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="App CPU time: — ms / 1000 ms"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monitor_cpu_notice"
                        android:textSize="11sp"
                        android:alpha="0.6"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
